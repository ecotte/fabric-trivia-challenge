  "queries": [
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "let pool=\r\nraw_events\r\n| where eventName == \"game.start\"\r\n| extend pool=tostring(context.poolName)\r\n| extend session=tostring(context.sessionId)\r\n| project pool, userId, session;\r\n_todaysevents\r\n| where eventName == \"game.answerquestion\"\r\n| extend\r\n    questionId = tostring(properties.questionId),\r\n    station= tostring(context.stationId),\r\n    isCorrect = case(tobool(properties.isCorrect) == \"true\", \"correct\", \"incorrect\") \r\n    | summarize arg_max(timestamp, *) by station\r\n    | sort by timestamp\r\n    | lookup external_table('Questions') on $left.questionId == $right.id\r\n    | extend session = tostring(properties.sessionId)\r\n    | lookup pool on session\r\n    | project questionText, isCorrect, station, pool\r\n    | extend loc = case (station == \"quantumqueryist\", \"1\", station == \"dashboarddruid\", \"2\", station == \"insightsalchemist\", \"3\", \"\")\r\n    | sort by loc asc",
      "id": "32c97b1c-0c33-4cdd-90a0-778f7681d678",
      "usedVariables": [
        "_todaysevents"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "let _users = currentSession(startofday(now()))\n| project userName;\n_users\n| union (datatable(userName:string)[\"Waiting for Players\"] | where toscalar(_users | count ) == 0)",
      "id": "22cc2846-1768-4e87-aba8-c0bf95321278",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "_todaysevents\n    | where eventName == \"game.answerquestion\"\n    | sort by timestamp\n    | limit 100\n    | extend Rtime = toint(properties.responseTime)/1000\n    ",
      "id": "846fe032-2836-4bb8-b0c0-ecc5b484d22f",
      "usedVariables": [
        "_todaysevents"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "raw_events\n    | where eventName == \"game.answerquestion\"\n    | extend category = tostring(properties.category)\n    | extend answer = case (tobool(properties.isCorrect)== true, \"correct\", \"incorrect\")\n    | summarize count() by category, answer\n    | sort by category asc\n",
      "id": "d6eafb1e-0f28-4274-a869-72cc1d274e83",
      "usedVariables": []
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "let name=\n_todaysevents\n    | where eventName == \"user.register\"\n    | distinct userId, userName = tostring(properties.name);\n_todaysevents\n| where eventName == \"game.answerquestion\"\n| where tobool(properties.isCorrect) == true\n| summarize responseTime=strcat(round(avg(toint(properties.responseTime))), \" ms\") by userId\n| lookup name on userId\n| sort by responseTime asc\n| limit 3\n",
      "id": "7e5e726d-ab12-4a01-9b4c-6605ae725b8c",
      "usedVariables": [
        "_todaysevents"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "allSessions(_eventDate)\n| summarize count() by pool",
      "id": "973cd37e-093f-484f-9a48-1d378ae6b5e6",
      "usedVariables": [
        "_eventDate"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "let pool=\n    raw_events\n    | where eventName == \"game.start\"\n    | extend pool=tostring(context.poolName)\n    | extend session=tostring(context.sessionId)\n    | project pool, userId, session;\n_todaysevents\n| where eventName == \"game.answerquestion\"\n| extend station= tostring(context.stationId)\n| summarize arg_max(timestamp, *) by station\n| sort by timestamp\n| extend session = tostring(properties.sessionId)\n| lookup pool on session\n| project station, pool\n| extend loc = case (station == \"quantumqueryist\", \"1\", station == \"dashboarddruid\", \"2\", station == \"insightsalchemist\", \"3\", \"\")\n//| where loc == 1\n| lookup Images on $left.pool == $right.Name\n| extend FinalCard = strcat(\n    \"|   |\\n\",\n    \"| :-: |\\n\",\n    \"| ![\",pool, \"](\", URL, \") |\"\n)\n| project FinalCard\n",
      "id": "89c68714-ef74-4969-af7f-df404196cd03",
      "usedVariables": [
        "_todaysevents"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "let pool=\n    raw_events\n    | where eventName == \"game.start\"\n    | extend pool=tostring(context.poolName)\n    | extend session=tostring(context.sessionId)\n    | project pool, userId, session;\n_todaysevents\n| where eventName == \"game.answerquestion\"\n| extend station= tostring(context.stationId)\n| summarize arg_max(timestamp, *) by station\n| sort by timestamp\n| extend session = tostring(properties.sessionId)\n| lookup pool on session\n| project station, pool\n| extend loc = case (station == \"quantumqueryist\", \"1\", station == \"dashboarddruid\", \"2\", station == \"insightsalchemist\", \"3\", \"\")\n//| where loc == 2\n| lookup Images on $left.pool == $right.Name\n| extend FinalCard = strcat(\n    \"|   |\\n\",\n    \"| :-: |\\n\",\n    \"| ![\",pool, \"](\", URL, \") |\"\n)\n| project FinalCard\n",
      "id": "2a6df17a-3a4a-4085-ac06-94676925a392",
      "usedVariables": [
        "_todaysevents"
      ]
    },
    {
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "let pool=\n    raw_events\n    | where eventName == \"game.start\"\n    | extend pool=tostring(context.poolName)\n    | extend session=tostring(context.sessionId)\n    | project pool, userId, session;\n_todaysevents\n| where eventName == \"game.answerquestion\"\n| extend station= tostring(context.stationId)\n| summarize arg_max(timestamp, *) by station\n| sort by timestamp\n| extend session = tostring(properties.sessionId)\n| lookup pool on session\n| project station, pool\n| extend loc = case (station == \"quantumqueryist\", \"1\", station == \"dashboarddruid\", \"2\", station == \"insightsalchemist\", \"3\", \"\")\n//| where loc == 3\n| lookup Images on $left.pool == $right.Name\n| extend FinalCard = strcat(\n    \"|   |\\n\",\n    \"| :-: |\\n\",\n    \"| ![\",pool, \"](\", URL, \") |\"\n)\n| project FinalCard\n",
      "id": "147b81b5-329e-4f89-896b-f842bd616136",
      "usedVariables": [
        "_todaysevents"
      ]
    },
    {
      "id": "eb98abf5-6b9b-43bf-931d-145c54d402a4",
      "dataSource": {
        "kind": "inline",
        "dataSourceId": "c5f76ee9-8b0b-4b09-914c-ab8f8984edd6"
      },
      "text": "raw_events\n| extend timestamp=datetime_utc_to_local(timestamp,'US/Eastern')\n| where timestamp between (startofday(_eventDate)..endofday(_eventDate))",
      "usedVariables": [
